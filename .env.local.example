# Variables d'environnement nécessaires pour le backend admin.
#
# NE JAMAIS remplir ce fichier avec les vraies valeurs et le commit sur GitHub.
# Ce fichier est juste un exemple. Les vraies valeurs se configurent dans
# Vercel → Settings → Environment Variables.

# Mot de passe pour accéder à /admin et publier des changements
ADMIN_PASSWORD=change-moi

# Personal Access Token GitHub (Settings → Developer settings → Tokens classic)
# Permission requise : "repo" (accès complet au repo)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Propriétaire et nom du repo GitHub où vivent les fichiers du site
GITHUB_REPO_OWNER=Imrane-Mou
GITHUB_REPO_NAME=enerfyh-site-project-template
